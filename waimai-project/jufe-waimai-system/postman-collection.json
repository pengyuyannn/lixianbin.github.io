    {
      "name": "购物车管理",
      "item": [
        {
          "name": "获取购物车列表",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "http://localhost:8080/api/cart/student/1",
              "protocol": "http",
              "host": ["localhost"],
              "port": "8080",
              "path": ["api", "cart", "student", "1"]
            }
          }
        },
        {
          "name": "添加到购物车",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"studentId\": 1,\n  \"merchantId\": 1,\n  \"productId\": 1,\n  \"productName\": \"宫保鸡丁饭\",\n  \"productImage\": \"https://example.com/product1.jpg\",\n  \"productPrice\": 18.00,\n  \"quantity\": 1\n}"
            },
            "url": {
              "raw": "http://localhost:8080/api/cart",
              "protocol": "http",
              "host": ["localhost"],
              "port": "8080",
              "path": ["api", "cart"]
            }
          }
        },
        {
          "name": "更新购物车商品数量",
          "request": {
            "method": "PUT",
            "header": [],
            "url": {
              "raw": "http://localhost:8080/api/cart/1?quantity=2",
              "protocol": "http",
              "host": ["localhost"],
              "port": "8080",
              "path": ["api", "cart", "1"],
              "query": [
                {
                  "key": "quantity",
                  "value": "2"
                }
              ]
            }
          }
        },
        {
          "name": "清空购物车",
          "request": {
            "method": "DELETE",
            "header": [],
            "url": {
              "raw": "http://localhost:8080/api/cart/student/1",
              "protocol": "http",
              "host": ["localhost"],
              "port": "8080",
              "path": ["api", "cart", "student", "1"]
            }
          }
        }
      ]
    },
    {
